# Vm-watchdog deploy credentials and infrastructure settings
# Copy to creds.env and fill in your values. creds.env is gitignored.

# SSH password used for all VMs listed in vms.conf
VM_PASS="your-vm-ssh-password"

# GitHub raw URL for this repo (used by bootstrap and self-update)
# If you forked the repo, change this to your fork's URL
REPO_RAW="https://raw.githubusercontent.com/YOUR-GITHUB-USER/Vm-watchdog/main"

# LAN subnet(s) allowed to SSH into your VMs
# Use a broad private range if you access via VPN tunnel (e.g. 10.0.0.0/8)
LAN_SUBNET="192.168.1.0/24"

# Uptime Kuma instance (for push monitor heartbeats and disk alerts)
UPTIME_HOST="192.168.1.x"        # IP of the machine running Uptime Kuma
UPTIME_USER="your-ssh-user"       # SSH user on that machine
UPTIME_PASS="your-ssh-password"   # SSH password (can be same as VM_PASS)
UPTIME_BASE_URL="https://your-uptime-kuma-domain.com"

# Uptime Kuma Docker settings
UPTIME_CONTAINER="uptime-kuma"    # Docker container name
UPTIME_DB_PATH="/app/data/kuma.db"

# Uptime Kuma internal IDs
# Find these by querying the SQLite database:
#   docker exec uptime-kuma sqlite3 /app/data/kuma.db "SELECT id, name FROM notification;"
#   docker exec uptime-kuma sqlite3 /app/data/kuma.db "SELECT id, username FROM user;"
NOTIFICATION_ID="1"   # ID of the notification channel to attach to push monitors
USER_ID="1"           # Uptime Kuma admin user ID
