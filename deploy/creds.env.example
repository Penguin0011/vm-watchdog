# Copy this file to creds.env and fill in your values.
# creds.env is gitignored and must never be committed.

# SSH password for all VMs (used by deploy-all.sh)
VM_PASS="your-vm-password"

# Uptime Kuma host credentials (used by create-monitors.sh)
UPTIME_HOST="10.0.0.7"
UPTIME_USER="uptime"
UPTIME_PASS="your-uptime-password"

# Uptime Kuma settings (defaults match this homelab)
UPTIME_BASE_URL="https://uptime.clouddev.dad"
NOTIFICATION_ID="4"    # Telegram notification ID in Uptime Kuma
USER_ID="1"            # Uptime Kuma admin user ID
